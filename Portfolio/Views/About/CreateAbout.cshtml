@model About
@{
    ViewData["Title"] = "Yeni Hakkımda Bilgisi Ekle";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}

<form method="post" >
    <label>Başlık</label>
    <input type="text" asp-for="Title" class="form-control" required>
    <br />

    <label>Description</label>
    <textarea asp-for="Description" class="form-control" required></textarea>
    <br />

    <label>Görsel Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" required>
    <br />

	<button type="submit" class="btn btn-outline-dark">Kaydet</button>

</form>

