@model List<Project>
@{
    ViewData["Title"] = "Projelerim";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}

<table class="table table-hover table-bordered">
    <tr>
        <th>Görsel</th>
        <th>Proje Adı</th>
        <th>Proje Açıklaması</th>
        <th>Github Linki</th>
        <th>İşlemler</th>
    </tr>
    @foreach(var item in Model)
    {
        <tr>
            <td><img src="@item.ImageUrl" style="height:50px;width:50px" /></td>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td><a href="@item.GithubUrl" class="btn btn-outline-dark" target="_blank">GitHub Url</a></td>
            <td>
                <button onclick="deleteProject(@item.Id)" class="btn btn-outline-info">Sil</button>
                <a href="/Project/UpdateProject/@item.Id" class="btn btn-outline-info">Düzenle</a>
              
                
            </td>
        </tr>
	}

    
</table>
<a href="#" class="btn btn-outline-dark">Yeni Proje Oluştur</a>

<script>
    function deleteProject(id){
            Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlwmi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText: "İptal",
    }).then((result) => {
      if (result.isConfirmed)

	  window.location.href = "/Project/DeleteProject/" + id;

    });
    }
</script>
