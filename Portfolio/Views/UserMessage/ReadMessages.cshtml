@model List<UserMessage>
@{
    ViewData["Title"] = "Okunan Mesajlar";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}

<div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-surface-container text-on-surface-variant border-b border-outline-variant">
                <th class="px-lg py-md font-label-sm uppercase tracking-wider">Gönderen Adı</th>
                <th class="px-lg py-md font-label-sm uppercase tracking-wider">Gönderen Mail</th>
                <th class="px-lg py-md font-label-sm uppercase tracking-wider">Mesaj İçeriği</th>
             
                <th class="px-lg py-md font-label-sm uppercase tracking-wider text-right">Mesajı Sil</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/30">

           @foreach(var item in Model)
           {
            <tr class="hover:bg-surface-container-lowest/50 transition-colors">
                <td class="px-lg py-md">
                   @item.Name
                </td>
                <td class="px-lg py-md text-on-surface-variant">@item.Mail</td>
                    <td class="px-lg py-md text-on-surface-variant">@item.MessageBody.ToString().Substring(0, 50) ...</td>
                
                <td class="px-lg py-md text-right">
                    <div class="flex justify-end gap-sm">

                            <button  class="p-4 text-on-surface-variant hover:text-error hover:bg-error-container/20 rounded-md transition-all">
                            <span class="material-symbols-outlined text-[20px]">delete</span>
                        </button>
                    </div>
                </td>
            </tr>
           }
            
        </tbody>
    </table>
</div>

