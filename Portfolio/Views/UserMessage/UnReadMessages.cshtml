@model List<UserMessage>
@{
    ViewData["Title"] = "Okunmayan Mesajlar";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}

<div class="overflow-x-auto">
   
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-surface-container text-on-surface-variant border-b border-outline-variant">
              
                <th class="px-lg py-md font-label-sm uppercase tracking-wider">Gönderen Adı</th>
                <th class="px-lg py-md font-label-sm uppercase tracking-wider">Gönderen Mail</th>
                <th class="px-lg py-md font-label-sm uppercase tracking-wider">Mesaj İçeriği</th>
                <th></th>
                <th></th>
                <th></th>
            
            </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/30">

            @foreach (var item in Model)
            {

                <tr class="hover:bg-surface-container-lowest/50 transition-colors">
                    <td style="display: none";  >@item.Id</td>
                    <td class="px-lg py-md">
                        @item.Name
                    </td>
                    <td class="px-lg py-md text-on-surface-variant">@item.Mail</td>
                    <td class="px-lg py-md text-on-surface-variant"> @item.MessageBody.ToString().Substring(0,50) ... </td>
                    <td class="px-lg py-md text-on-surface-variant"> <button href="" type="button" data-bs-toggle="modal" data-bs-target="#exampleModal" class="btn btn-outline-primary btn-sm"> Görüntüle </button></td>

                    <td>
                        <a asp-controller="UserMessage"
                           asp-action="ChangeStatus"
                           asp-route-id="@item.Id"
                           class="btn btn-success">
                            Okundu Olarak İşaretle 
                        </a>
                    </td>
                    <td class="px-lg py-md text-right">
                        <div class="flex justify-end gap-sm">

                            <button class="p-4 text-on-surface-variant hover:text-error hover:bg-error-container/20 rounded-md transition-all">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            }

        </tbody>
    </table>


    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="exampleModalLabel">Modal title</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    This is some placeholder content to show the scrolling behavior for modals. We use repeated line breaks to demonstrate how content can exceed minimum inner height, thereby showing inner scrolling. When content becomes longer than the predefined max-height of modal, content will be cropped and scrollable within the modal.
